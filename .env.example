# MongoDB — copie para .env e ajuste os valores
# URI completa (usuário/senha podem ir na string, conforme seu provedor)
MONGODB_URI=mongodb://127.0.0.1:27017/proconbot_jacarei
MONGODB_DB_NAME=proconbot_jacarei

# Opcional: sobrescreve o nome do banco na URI
# MONGODB_DB_NAME=proconbot_jacarei

# WhatsApp - informe o numero do WhatsApp em formato internacional
# para ativar o pareamento por codigo em vez de QR.
# O valor pode ser salvo com pontuacao; o sistema normaliza automaticamente.
# Ex.: +55 (11) 99999-9999 -> 5511999999999
# WHATSAPP_PHONE_NUMBER=5511999999999

# MongoDB — copie para .env e ajuste os valores
# URI completa (usuário/senha podem ir na string, conforme seu provedor)
MONGODB_URI=mongodb://127.0.0.1:27017/proconbot_jacarei
MONGODB_DB_NAME=proconbot_jacarei

# Gemini API — obrigatório para RAG (busca semântica + geração com LLM)
# Obtenha gratuitamente em: https://aistudio.google.com/apikey
# Sem esta chave, o sistema usa busca por keyword como fallback.
GEMINI_API_KEY=sua_chave_aqui

# Opcional: sobrescreve o nome do banco na URI
# MONGODB_DB_NAME=proconbot_jacarei

# WhatsApp - informe o numero do WhatsApp em formato internacional
# para ativar o pareamento por codigo em vez de QR.
# O valor pode ser salvo com pontuacao; o sistema normaliza automaticamente.
# Ex.: +55 (11) 99999-9999 -> 5511999999999
# WHATSAPP_PHONE_NUMBER=5511999999999

# Opcional: diretorio da sessao do WhatsApp.
# Em containers, aponte para um volume persistente para evitar novo login em redeploy.
# Ex.: WHATSAPP_AUTH_PATH=/data/.wwebjs_auth
# WHATSAPP_AUTH_PATH=.wwebjs_auth

# Opcional: liga logs do Chromium/Puppeteer e do console da pagina.
# Use "true" para diagnosticar falhas no pareamento por codigo na Railway.
# WHATSAPP_BROWSER_LOGS=false

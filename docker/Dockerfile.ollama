# Ollama — serviço de embeddings para o ProconBot
# Baseado na imagem oficial do Ollama
# Ao iniciar, baixa automaticamente o modelo nomic-embed-text

FROM ollama/ollama:latest

COPY docker/ollama-entrypoint.sh /ollama-entrypoint.sh
RUN chmod +x /ollama-entrypoint.sh

EXPOSE 11434

ENTRYPOINT ["/ollama-entrypoint.sh"]
